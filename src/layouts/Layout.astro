---
import Header from "@/components/Header.astro";
import { ClientRouter } from "astro:transitions";

import "@/styles/global.css"
interface Props {
	title: string
}
const { title } = Astro.props
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/webp" href="/favicon.webp">
		
		<title>{title}</title>
		<ClientRouter />
	</head>
	<body class="bg-zinc-900 text-white h-screen flex flex-col">
        <div class="absolute top-0 left-0 w-full z-50">
            <Header />
        </div>
        
        <main class="flex-1 overflow-y-auto pt-24 scroll-smooth scroll-pt-30">
            <slot />
        </main>
    </body>
</html>

<style is:global>
    /* ESTILO DE LA BARRA QUE SEPARA LOS CONTENEDORES */
    .gutter {
        background-color: #52525b; /* zinc-600 */
        background-repeat: no-repeat;
        background-position: center;
        transition: background-color 0.2s;
    }

    .gutter:hover {
        background-color: #a1a1aa; /* Hover */
    }

    .gutter.gutter-horizontal { /* Cambia el cursor al arrastrar */
        cursor: col-resize;
    }

    /* BARRA INDIVIDUAL DEL CONTENEDOR */
    ::-webkit-scrollbar {
        width: 12px;
    }
    ::-webkit-scrollbar-track {
        background: #18181b; /* zinc-900 */
    }
    ::-webkit-scrollbar-thumb {
        background: #3f3f46; /* zinc-700 */
        border-radius: 10px;
        border: 2px solid #18181b; /* Crea un efecto de margen */
    }
    ::-webkit-scrollbar-thumb:hover { /* Hover */
        background: #52525b; /* zinc-600 */ 
    }
</style>